@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject FirebaseAuthenticationService AuthService
@inject NavigationManager NavManager

@inherits LayoutComponentBase
<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
            <AuthorizeView>
                <Authorized>
                    <div class="d-flex gap-2 align-items-center">
                        <span class="text-muted small">
                            @(context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "Usuario")
                        </span>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="HandleLogout">
                            Cerrar Sesión
                        </button>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        
        // Notificar al AuthenticationStateProvider
        var authProvider = AuthStateProvider as Ticketing.Front.Authentication.FirebaseAuthenticationStateProvider;
        authProvider?.NotifyUserLoggedOut();
        
        NavManager.NavigateTo("/login");
    }
}
