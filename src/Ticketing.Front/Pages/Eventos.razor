@page "/eventos"
@using Ticketing.Contracts.Eventos
@using Ticketing.Front.ApiClients
@inject EventosApiClient Client

<PageTitle>Eventos</PageTitle>

<h1>Eventos deportivos</h1>

@if (_error is not null)
{
    <p style="color:red">@_error</p>
}
else if (_eventos is null)
{
    <p>Cargando...</p>
}
else if (_eventos.Count == 0)
{
    <p>No hay eventos.</p>
}
else
{
    <table class="table">
        <thead><tr><th>Id</th><th>Local</th><th>Visitante</th><th>Estadio</th><th>Fecha</th><th>Hora</th><th>Disponibles</th></tr></thead>
        <tbody>
        @foreach (var e in _eventos)
        {
            <tr><td>@e.Id</td><td>@e.NombreLocal</td><td>@e.NombreVisitante</td><td>@e.NombreEstadio</td><td>@e.Fecha</td><td>@e.Hora</td><td>@e.EntradasDisponibles</td></tr>
        }
        </tbody>
    </table>
}

@code {
    private IReadOnlyList<EventoResponse>? _eventos;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _eventos = await Client.GetAllAsync();
        }
        catch (Exception ex)
        {
            _error = $"Error llamando a la API: {ex.Message}";
        }
    }
}
