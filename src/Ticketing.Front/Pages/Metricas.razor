@page "/metricas"
@using Ticketing.Contracts.Metricas
@using Ticketing.Front.ApiClients
@inject MetricasApiClient Client

<PageTitle>Métricas</PageTitle>

<h1>Métricas</h1>

@if (_error is not null)
{
    <p style="color:red">@_error</p>
}
else if (_eventos is null || _compradores is null)
{
    <p>Cargando...</p>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <h2>Eventos más vendidos</h2>
            <table class="table">
                <thead><tr><th>Evento</th><th>Entradas vendidas</th></tr></thead>
                <tbody>
                @foreach (var e in _eventos)
                {
                    <tr><td>@e.IdEventoDeportivo</td><td>@e.EntradasVendidas</td></tr>
                }
                </tbody>
            </table>
        </div>
        <div class="col-md-6">
            <h2>Mayores compradores</h2>
            <table class="table">
                <thead><tr><th>Usuario</th><th>Email</th><th>Entradas Compradas</th></tr></thead>
                <tbody>
                @foreach (var c in _compradores)
                {
                    <tr><td>@c.NumeroDocumentoUsuario</td><td>@c.Mail</td><td>@c.EntradasCompradas</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private IReadOnlyList<EventoMasVendidoResponse>? _eventos;
    private IReadOnlyList<MayorCompradorResponse>? _compradores;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _eventos = await Client.GetEventosMasVendidosAsync();
            _compradores = await Client.GetMayoresCompradoresAsync();
        }
        catch (Exception ex)
        {
            _error = $"Error llamando a la API: {ex.Message}";
        }
    }
}
