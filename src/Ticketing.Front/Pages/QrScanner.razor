@page "/qr-scanner"
@page "/validar-entrada"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using Ticketing.Contracts.Entradas
@using Ticketing.Front.ApiClients
@using Ticketing.Front.Services
@using Ticketing.Front.Utils
@inject HttpClient HttpClient
@inject ILogger<QrScanner> Logger
@inject FirebaseAuthenticationService AuthService
@inject ToastService Toast
@inject DispositivosApiClient DispositivosClient

<PageTitle>Validar Entrada</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg">
                <div class="card-body p-5">
                    <h1 class="card-title mb-4">Validar Entrada</h1>

                    @if (IsLoading)
                    {
                        <p class="text-muted">Cargando datos...</p>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label for="entrada" class="form-label">Entrada</label>
                            <input type="text" class="form-control" id="entrada" placeholder="Ingresá el ID de la entrada" @bind="SelectedEntradaId" disabled="@IsValidating" />
                        </div>

                        <div class="mb-3">
                            <label for="dispositivo" class="form-label">Dispositivo autorizado</label>
                            <select class="form-select" id="dispositivo" @bind="SelectedDispositivoId" disabled="@IsValidating">
                                <option value="">Selecciona un dispositivo</option>
                                @foreach (var d in Dispositivos)
                                {
                                    <option value="@d.Id">@d.Nombre</option>
                                }
                            </select>
                        </div>

                        <button
                            class="btn btn-primary w-100"
                            @onclick="HandleValidar"
                            disabled="@(IsValidating || string.IsNullOrEmpty(SelectedEntradaId) || string.IsNullOrEmpty(SelectedDispositivoId) || !EsIdValido(SelectedEntradaId))">
                            @if (IsValidating)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Validando...</span>
                            }
                            else
                            {
                                <span>Validar Entrada</span>
                            }
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<EntradaResponse> Entradas = new();
    private List<DispositivosApiClient.DispositivoDto> Dispositivos = new();
    private string SelectedEntradaId = "";
    private string SelectedDispositivoId = "";
    private string? MiDocumento;
    private bool IsLoading = true;
    private bool IsValidating;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var role = await AuthService.GetUserRoleAsync();
            MiDocumento = role?.NumeroDocumento;
            Logger.LogInformation("Usuario: {MiDocumento}, Rol: {Rol}", MiDocumento, role?.Role);

            // Cargar todas las entradas no validadas
            try
            {
                var response = await HttpClient.GetAsync("api/Entradas/sin-validar");
                Logger.LogInformation("Respuesta de Entradas: {Status}", response.StatusCode);
                
                if (response.IsSuccessStatusCode)
                {
                    var json = await response.Content.ReadFromJsonAsync<List<EntradaResponse>>();
                    Entradas = json ?? new();
                    Logger.LogInformation("Entradas cargadas: {Count}", Entradas.Count);
                }
                else
                {
                    var errorContent = await response.Content.ReadAsStringAsync();
                    Logger.LogError("Error cargando entradas: {Status} - {Error}", response.StatusCode, errorContent);
                    Toast.ShowError($"Error cargando entradas: {response.StatusCode}");
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Excepción cargando entradas");
                Toast.ShowError("Error al cargar entradas");
            }

            // Cargar dispositivos del funcionario logueado
            if (!string.IsNullOrEmpty(MiDocumento))
            {
                try
                {
                    Dispositivos = (await DispositivosClient.GetByFuncionarioAsync(MiDocumento)).ToList();
                    Logger.LogInformation("Dispositivos cargados: {Count}", Dispositivos.Count);
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, "Excepción cargando dispositivos");
                    Toast.ShowError("Error al cargar dispositivos");
                }
            }
            else
            {
                Logger.LogWarning("MiDocumento es null");
                Toast.ShowError("No se pudo obtener el documento del usuario");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error en OnInitializedAsync");
            Toast.ShowError("Error inesperado");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task HandleValidar()
    {
        if (string.IsNullOrEmpty(SelectedEntradaId) || string.IsNullOrEmpty(SelectedDispositivoId))
        {
            Toast.ShowError("Por favor completa todos los campos");
            return;
        }

        // Sanitizar el ID de entrada
        var idSanitizado = InputSanitizer.SanitizeNumeric(SelectedEntradaId);
        if (string.IsNullOrEmpty(idSanitizado) || !int.TryParse(idSanitizado, out var idEntrada))
        {
            Toast.ShowError("El ID de entrada ingresado no es válido.");
            return;
        }

        IsValidating = true;

        try
        {
            var request = new
            {
                IdEntrada = idEntrada,
                IdDispositivo = int.Parse(SelectedDispositivoId)
            };

            var response = await HttpClient.PostAsJsonAsync("api/Validacion/validar-acceso", request);

            if (response.IsSuccessStatusCode)
            {
                Toast.ShowSuccess("Entrada validada correctamente.");
                // Recargar la lista para que la entrada desaparezca
                Entradas.RemoveAll(e => e.Id.ToString() == SelectedEntradaId);
                SelectedEntradaId = "";
                SelectedDispositivoId = "";
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                Toast.ShowError("No se pudo validar la entrada.");
                Logger.LogWarning("Error validando: {Status} - {Content}", response.StatusCode, content);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al validar entrada");
            Toast.ShowError("Error inesperado al validar");
        }
        finally
        {
            IsValidating = false;
        }
    }

    private bool EsIdValido(string id)
    {
        return int.TryParse(id, out _);
    }
}
